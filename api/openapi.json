  "servers": [
    {
      "url": "{protocol}://{host}:{port}",
      "description": "Local server",
      "variables": {
        "host": {
          "default": "localhost",
          "description": "The host"
        },
        "port": {
          "default": "3140",
          "description": "The port number"
        },
        "protocol": {
          "default": "http",
          "description": "The protocol"
        }
      }
    }
  ],
