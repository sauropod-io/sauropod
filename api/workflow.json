{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Workflow",
  "description": "A workflow.",
  "type": "object",
  "properties": {
    "actions": {
      "description": "The tasks in the workflow.\n\n The keys are the IDs of the tasks.",
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/WorkflowAction"
      }
    },
    "connections": {
      "description": "A mapping of connections between tasks.\n\n # Example\n\n ```json\n [\n   {\n     // Make the workflow parameter `url` available to the task `foo`.\n     \"parameter\": \"url\",\n     \"to\": \"foo.url\"\n   },\n   {\n     // Pipe the output of the `foo` task to the `content` parameter of task `bar`.\n     \"from\": \"foo.output\",\n     \"to\": \"bar.content\"\n   }\n   {\n     // Pipe the output of the `bar` task to the `my_output` output of the workflow.\n     \"from\": \"bar.output\",\n     \"output\": \"my_output\"\n   }\n ]\n ```",
      "type": "array",
      "default": [],
      "items": {
        "$ref": "#/$defs/Connection"
      }
    },
    "name": {
      "description": "The name of the workflow.",
      "type": "string",
      "examples": ["Process shipping emails"]
    }
  },
  "additionalProperties": false,
  "required": ["name", "actions"],
  "$defs": {
    "Connection": {
      "description": "A connection.",
      "anyOf": [
        {
          "description": "A parameter passed in from outside the workflow.",
          "type": "object",
          "properties": {
            "parameter": {
              "description": "The name of the parameter.",
              "type": "string",
              "examples": ["url"]
            },
            "to": {
              "description": "The task parameter to connect the workflow parameter to.",
              "type": "string",
              "examples": ["uploader.target_url"]
            }
          },
          "additionalProperties": false,
          "required": ["parameter", "to"]
        },
        {
          "description": "An output from workflow.",
          "type": "object",
          "properties": {
            "from": {
              "description": "The task parameter to connect to the output.",
              "type": "string",
              "examples": ["retriever.content"]
            },
            "output": {
              "description": "The name of the output value.",
              "type": "string",
              "examples": ["document_content"]
            }
          },
          "additionalProperties": false,
          "required": ["from", "output"]
        },
        {
          "description": "A connection between the output of one task and the input of another.",
          "type": "object",
          "properties": {
            "from": {
              "description": "The ID of the task that produces the output.",
              "type": "string",
              "examples": ["retriever.content"]
            },
            "to": {
              "description": "The ID of the task that consumes the output.",
              "type": "string",
              "examples": ["summarizer.document"]
            }
          },
          "additionalProperties": false,
          "required": ["from", "to"]
        }
      ]
    },
    "TaskId": {
      "description": "A task ID.",
      "type": "object",
      "properties": {
        "taskId": {
          "description": "The ID of the task.",
          "type": "integer",
          "format": "int64",
          "examples": [12345]
        }
      },
      "additionalProperties": false,
      "required": ["taskId"]
    },
    "WorkflowAction": {
      "description": "A task a workflow will perform.",
      "anyOf": [
        {
          "description": "Run a task.",
          "$ref": "#/$defs/TaskId"
        },
        {
          "description": "Run a workflow.",
          "$ref": "#/$defs/WorkflowId"
        },
        {
          "description": "Run a tool.",
          "type": "object",
          "properties": {
            "toolId": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "required": ["toolId"]
        }
      ]
    },
    "WorkflowId": {
      "description": "A workflow ID.",
      "type": "object",
      "properties": {
        "workflowId": {
          "description": "The ID of the workflow.",
          "type": "integer",
          "format": "int64",
          "examples": [12345]
        }
      },
      "additionalProperties": false,
      "required": ["workflowId"]
    }
  }
}
